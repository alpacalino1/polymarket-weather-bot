# Polymarket Weather Trading Bot - Environment Configuration

# === Polymarket ===
# Your Polymarket wallet private key (from Polymarket account → API keys)
# This is the private key of your Polygon wallet, not your seed phrase
POLYMARKET_PRIVATE_KEY=

# Optional: Polymarket API key (if using API-key auth instead of wallet)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# CLOB API endpoint (default: production)
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# Gamma API endpoint (for market discovery)
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# Chain ID: 137 = Polygon mainnet, 80001 = Mumbai testnet
POLYMARKET_CHAIN_ID=137

# === Trading ===
# Maximum USDC position per market
MAX_POSITION_USDC=100

# Minimum edge (probability difference) required to trade (0.05 = 5%)
MIN_EDGE=0.05

# Maximum number of concurrent positions
MAX_CONCURRENT_POSITIONS=5

# Cooldown in minutes between checks of the same market
MARKET_CHECK_COOLDOWN_MINUTES=30

# === Bot Mode ===
# "scan" = only find opportunities, don't trade
# "paper" = paper trade (log trades, nothing real)
# "live" = real trading with real USDC
BOT_MODE=scan

# Scan interval in minutes (how often to check for new markets)
SCAN_INTERVAL_MINUTES=15

# === Weather APIs ===
# Open-Meteo (free, no key needed - always available)
# National Weather Service (free, no key needed - US only)

# OpenWeatherMap free tier key (optional, for additional data)
OPENWEATHERMAP_API_KEY=

# Weatherbit free tier key (optional)
WEATHERBIT_API_KEY=

# === Risk Management ===
# Maximum total exposure in USDC across all positions
MAX_TOTAL_EXPOSURE_USDC=500

# Maximum daily loss in USDC (stops trading if exceeded)
MAX_DAILY_LOSS_USDC=200

# Minimum market volume (24h) in USDC to consider trading
MIN_MARKET_VOLUME_USDC=1000

# === Locations ===
# Comma-separated list of cities/states to focus on (empty = all US cities)
# Example: "New York,NY|Chicago,IL|Los Angeles,CA|Miami,FL|Houston,TX"
FOCUS_LOCATIONS=

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=bot.log
